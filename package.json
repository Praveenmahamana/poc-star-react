{
  "name": "insightsdb-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-data": "node scripts/sync-data.mjs",
    "dev": "npm run serve:dist",
    "build": "npm run sync-data && vite build && node scripts/copy-public-to-dist.mjs",
    "check:frg:parity": "python scripts/check_frg_parity.py --frg ../frg.xlsx --workset-dir ../WORKSET12139 --host-airline S5 --corrections public/data/worksets/frg_corrections.json --output ../frg_parity_report.json",
    "export:network": "node scripts/export-network-html.mjs",
    "export:dashboard": "node scripts/export-dashboard-html.mjs",
    "preview": "npm run serve:dist",
    "serve:dist": "node scripts/serve-dist.mjs",
    "rebuild:stable": "npm run build && npm run serve:dist",
    "start:stable": "npm run serve:dist"
  },
  "dependencies": {
    "@mantine/charts": "^8.3.18",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "vite": "^5.4.19"
  }
}
